{
  "media": {
    "root": "public/images",
    "public": "public/"
  },
  "content": {
    "root": "src/content"
  },
  "themeConfig": [],
  "arrangement": [
    {
      "type": "file",
      "targetPath": "src/content/homepage/-index.md",
      "groupName": "homepage"
    },
    {
      "type": "heading",
      "groupName": "blogs",
      "targetPath": ""
    },
    {
      "type": "folder",
      "targetPath": "src/content/blog",
      "groupName": "blogs",
      "include": "*.md, *.mdx",
      "exclude": ""
    },
    {
      "type": "file",
      "targetPath": "src/content/blog/post-1.md",
      "groupName": "post-1"
    }
  ],
  "showCommitModal": false
}