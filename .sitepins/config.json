{
  "media": {
    "root": "public/images",
    "public": "public/"
  },
  "content": {
    "root": "src/content"
  },
  "themeConfig": [],
  "arrangement": [
    {
      "type": "file",
      "targetPath": "src/content/homepage/-index.md",
      "groupName": "homepage"
    },
    {
      "type": "file",
      "targetPath": "src/content/about/-index.md",
      "groupName": "about"
    },
    {
      "type": "file",
      "targetPath": "src/content/contact/-index.md",
      "groupName": "contact"
    },
    {
      "type": "heading",
      "groupName": "sections",
      "targetPath": ""
    },
    {
      "type": "folder",
      "targetPath": "src/content/sections",
      "groupName": "sections",
      "include": "",
      "exclude": ""
    },
    {
      "type": "heading",
      "groupName": "blogs",
      "targetPath": ""
    },
    {
      "type": "folder",
      "targetPath": "src/content/blog",
      "groupName": "blogs",
      "include": "*.md, *.mdx",
      "exclude": "!*index.md"
    }
  ],
  "showCommitModal": false
}